# Show-Build Environment Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
DATABASE_URL=postgresql://showbuild:showbuild@show-build-postgres/showbuild

# Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=2880

# Media Storage Paths
# Root directory for all media storage
MEDIA_ROOT=/mnt/sync/disaffected

# Subdirectories under MEDIA_ROOT (relative paths)
EPISODES_PATH=episodes
SHOW_PATH=show
LIBRARY_PATH=lib

# For different show organizations, you could use:
# MEDIA_ROOT=/mnt/sync/myshow
# SHOW_PATH=branding
# LIBRARY_PATH=shared

# Upload Settings (in bytes)
MAX_UPLOAD_SIZE=104857600  # 100MB

# API Configuration
API_PREFIX=/api

# xAI/Grok API (for training data collection)
XAI_API_KEY=your-xai-api-key-here