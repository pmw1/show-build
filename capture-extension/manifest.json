{
  "manifest_version": 3,
  "name": "Show-Build Capture",
  "description": "Send links, media, text, and social posts from any page into a Show-Build episode whiteboard and media pool.",
  "version": "0.1.0",
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "notifications",
    "alarms",
    "unlimitedStorage"
  ],
  "host_permissions": ["https://showbuild.app/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
